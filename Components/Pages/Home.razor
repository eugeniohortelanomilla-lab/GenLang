@page "/"

<div class="hero-section">
    <div class="header-reveal">
        <div class="status-badge">
            <span class="dot"></span> READY FOR NEW CHALLENGES
        </div>
        
        <h1 class="clean-name">Eugenio Milla</h1>
        <p class="professional-tag">IT Specialist | Digital Entrepreneur</p>
    </div>

    <div class="bio-glass-panel">
        <p>
            Bridging the gap between <strong>Technical Analysis</strong> and <strong>Elite Creative Content</strong>. 
            I architect high-performance .NET systems while driving digital strategy through 
            multimedia production and journalistic precision.
        </p>
    </div>

    <div class="cta-group">
        <a href="projects" class="modern-pill-btn">
            <span>VIEW EXPERIENCE & SKILLS</span>
            <div class="shimmer"></div>
        </a>
        <a href="contact" class="link-btn">Contact Me</a>
    </div>
</div>

<style>
    .hero-section {
        height: 75vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        max-width: 800px;
    }

    /* STATUS BADGE */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 60, 60, 0.2);
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 800;
        letter-spacing: 1.5px;
        color: #ff3c3c;
        margin-bottom: 20px;
    }

    .dot { width: 6px; height: 6px; background: #ff3c3c; border-radius: 50%; box-shadow: 0 0 8px #ff3c3c; }

    /* TYPOGRAPHY */
    .clean-name {
        font-size: 5rem;
        font-weight: 900;
        margin: 0;
        color: white;
        letter-spacing: -2px;
        line-height: 1;
    }

    .professional-tag {
        font-size: 1.2rem;
        color: #ff3c3c;
        font-weight: 600;
        margin: 10px 0 0;
        letter-spacing: 1px;
    }

    .bio-glass-panel {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(10px);
        border-left: 2px solid #800020;
        padding: 25px 0 25px 30px;
        margin: 40px 0;
    }

    .bio-glass-panel p {
        margin: 0;
        color: #aaa;
        font-size: 1.1rem;
        line-height: 1.8;
    }

    /* MODERN PILL BUTTON */
    .cta-group { display: flex; align-items: center; gap: 30px; }

    .modern-pill-btn {
        position: relative;
        background: #800020;
        color: white;
        padding: 18px 35px;
        text-decoration: none;
        font-weight: 800;
        font-size: 0.85rem;
        letter-spacing: 1px;
        border-radius: 100px;
        overflow: hidden;
        transition: 0.4s;
        border: 1px solid rgba(255, 60, 60, 0.3);
    }

    .shimmer {
        position: absolute;
        top: 0; left: -100%; width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: 0.6s;
    }

    .modern-pill-btn:hover {
        background: #a30029;
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(128, 0, 32, 0.5);
    }

    .modern-pill-btn:hover .shimmer { left: 100%; }

    .link-btn {
        color: #888;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: 0.3s;
    }

    .link-btn:hover { color: white; }
</style>