@page "/contact"

<div class="contact-wrapper">
    <div class="header-zone">
        <h1 class="display-text">GET IN <span class="outline">TOUCH</span></h1>
        <p class="subtitle">Let's collaborate on your next digital venture.</p>
    </div>

    <div class="contact-grid">
        <div class="glass-form">
            <div class="input-group">
                <label>FULL NAME</label>
                <input type="text" placeholder="E.g. John Doe" />
            </div>

            <div class="input-group">
                <label>EMAIL ADDRESS</label>
                <input type="email" placeholder="john@example.com" />
            </div>

            <div class="input-group">
                <label>MESSAGE</label>
                <textarea rows="4" placeholder="How can I help you grow?"></textarea>
            </div>

            <button class="send-btn">
                <span>SEND MESSAGE</span>
                <div class="btn-glow"></div>
            </button>
        </div>

        <div class="contact-info">
            <div class="info-card">
                <span class="icon">📍</span>
                <div>
                    <h4>LOCATION</h4>
                    <p>Daanbantayan, Cebu, PH</p>
                </div>
            </div>

            <div class="info-card">
                <span class="icon">📧</span>
                <div>
                    <h4>EMAIL</h4>
                    <p>eugenio.milla@example.com</p>
                </div>
            </div>

            <div class="info-card">
                <span class="icon">💼</span>
                <div>
                    <h4>AVAILABILITY</h4>
                    <p>Freelance & Full-time</p>
                </div>
            </div>

            <div class="social-links">
                <a href="#" class="social-icon">Li</a>
                <a href="#" class="social-icon">Gh</a>
                <a href="#" class="social-icon">Fb</a>
            </div>
        </div>
    </div>
</div>

<style>
    .contact-wrapper { animation: fadeIn 1s ease-out; }
    .display-text { font-size: 4rem; font-weight: 900; margin: 0; line-height: 1; }
    .outline { color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.4); }
    .subtitle { color: #888; margin-top: 10px; font-weight: 500; letter-spacing: 1px; }

    .contact-grid { 
        display: grid; 
        grid-template-columns: 1.5fr 1fr; 
        gap: 40px; 
        margin-top: 50px; 
    }

    /* GLASS FORM STYLING */
    .glass-form {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 40px;
        border-radius: 24px;
    }

    .input-group { margin-bottom: 25px; }
    .input-group label { 
        display: block; 
        color: #ff3c3c; 
        font-size: 0.7rem; 
        font-weight: 900; 
        letter-spacing: 2px;
        margin-bottom: 10px;
    }

    .input-group input, .input-group textarea {
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 15px;
        color: white;
        border-radius: 12px;
        outline: none;
        transition: 0.3s;
    }

    .input-group input:focus, .input-group textarea:focus {
        border-color: #800020;
        background: rgba(128, 0, 32, 0.05);
        box-shadow: 0 0 15px rgba(128, 0, 32, 0.2);
    }

    /* THE BUTTON */
    .send-btn {
        width: 100%;
        padding: 20px;
        background: #800020;
        border: none;
        color: white;
        font-weight: 900;
        letter-spacing: 2px;
        border-radius: 12px;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: 0.3s;
    }

    .send-btn:hover {
        background: #ff3c3c;
        transform: translateY(-3px);
        box-shadow: 0 10px 30px rgba(255, 60, 60, 0.4);
    }

    /* INFO CARDS */
    .contact-info { display: flex; flex-direction: column; gap: 20px; }
    .info-card {
        display: flex;
        align-items: center;
        gap: 20px;
        background: rgba(255, 255, 255, 0.02);
        padding: 20px;
        border-radius: 15px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    .info-card h4 { margin: 0; font-size: 0.75rem; color: #ff3c3c; letter-spacing: 1px; }
    .info-card p { margin: 0; color: #ccc; }
    .icon { font-size: 1.5rem; }

    .social-links { display: flex; gap: 15px; margin-top: 20px; }
    .social-icon {
        width: 45px;
        height: 45px;
        background: rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        color: white;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }
    .social-icon:hover { background: #800020; transform: scale(1.1); }
</style>